# PostgreSQL
POSTGRES_USER=openflaskcards
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=openflaskcards
DATABASE_URL=postgres://openflaskcards:your_secure_password_here@db:5432/openflaskcards?sslmode=disable

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_here_make_it_random

# Redis
REDIS_TTS_HOST=redis
REDIS_TTS_PORT=6379
REDIS_TTS_DB=1

# Environment
ENVIRONMENT=development
LOG_LEVEL=debug

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Password reset emails. Leave SMTP_HOST empty to disable delivery (the
# reset flow still works, but the email is only logged, not sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
WEB_BASE_URL=http://localhost:5173
PASSWORD_RESET_TTL_MINUTES=30

# TTS Provider (google, elevenlabs, piper)
TTS_PROVIDER=google

# Google Cloud TTS (if using TTS_PROVIDER=google)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ElevenLabs TTS (if using TTS_PROVIDER=elevenlabs)
TTS_ELEVENLABS_API_KEY=
TTS_ELEVENLABS_VOICE_ID=
TTS_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TTS_ELEVENLABS_STABILITY=0.5
TTS_ELEVENLABS_SIMILARITY_BOOST=0.75
TTS_ELEVENLABS_STYLE=0
TTS_ELEVENLABS_USE_SPEAKER_BOOST=true
TTS_ELEVENLABS_SPEED=1.0
TTS_ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Piper TTS (if using TTS_PROVIDER=piper)
TTS_PIPER_BASE_URL=http://piper:5002
