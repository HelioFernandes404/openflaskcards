---
import { Github } from "lucide-react";
import type { Lang } from "../i18n/utils";
import { t } from "../i18n/utils";

interface Props {
  lang: Lang;
  class?: string;
}

const { lang, class: className = "" } = Astro.props;

const GITHUB_URL = "https://github.com/HelioFernandes404/openflashcards";
const QUICKSTART_URL =
  "https://github.com/HelioFernandes404/openflashcards#quick-start";

const focusClass =
  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-[3px] focus-visible:ring-offset-neutral-0";

const primaryClass =
  `flex-1 sm:flex-none flex items-center justify-center gap-2 text-center text-base font-medium cursor-pointer text-on-primary px-6 py-3 rounded-md bg-primary-500 hover:bg-primary-hover active:bg-primary-active active:scale-[0.98] transition-all duration-150 ease-out ${focusClass}`;

const secondaryClass =
  `flex-1 sm:flex-none flex items-center justify-center text-center text-base font-medium cursor-pointer border border-outline text-on-surface px-6 py-3 rounded-md hover:border-on-surface active:scale-[0.98] transition-all duration-150 ease-out ${focusClass}`;
---

<div class:list={["w-full flex flex-col sm:flex-row gap-3", className]}>
  <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class={primaryClass}>
    <Github size={18} />
    {t(lang, "cta_buttons.github")}
  </a>
  <a href={QUICKSTART_URL} target="_blank" rel="noopener noreferrer" class={secondaryClass}>
    {t(lang, "cta_buttons.quickstart")}
  </a>
</div>
