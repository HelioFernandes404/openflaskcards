---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Container from "../../components/Container.astro";
import Badge from "../../components/Badge.astro";
import CtaButtons from "../../components/CtaButtons.astro";
import { HomeCardsIsland } from "../../components/HomeCardsIsland";
import { FeaturesCarouselIsland } from "../../components/FeaturesCarouselIsland";
import { FAQIsland } from "../../components/FAQIsland";
import { languages, defaultLang, t, withBase, type Lang } from "../../i18n/utils";

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((lang) => ({
      params: { lang },
    }));
}

const { lang } = Astro.params as { lang: Lang };

const cards = [
  {
    title: t(lang, "home.cards.card1.title"),
    description: t(lang, "home.cards.card1.description"),
    imagePng: withBase("/learn.png"),
    imageWebp: withBase("/learn.webp"),
  },
  {
    title: t(lang, "home.cards.card2.title"),
    description: t(lang, "home.cards.card2.description"),
    imagePng: withBase("/repetition.png"),
    imageWebp: withBase("/repetition.webp"),
  },
  {
    title: t(lang, "home.cards.card3.title"),
    description: t(lang, "home.cards.card3.description"),
    imagePng: withBase("/day.png"),
    imageWebp: withBase("/day.webp"),
  },
  {
    title: t(lang, "home.cards.card4.title"),
    description: t(lang, "home.cards.card4.description"),
    imagePng: withBase("/graphic.png"),
    imageWebp: withBase("/graphic.webp"),
  },
];

const features = [
  {
    id: "textToSpeech",
    title: t(lang, "home.features.items.textToSpeech.title"),
    description: t(lang, "home.features.items.textToSpeech.description"),
    image: withBase("/text-to-speech.png"),
    imageWebp: withBase("/text-to-speech.webp"),
  },
  {
    id: "decks",
    title: t(lang, "home.features.items.decks.title"),
    description: t(lang, "home.features.items.decks.description"),
    image: withBase("/create-decks.png"),
    imageWebp: withBase("/create-decks.webp"),
  },
  {
    id: "ai",
    title: t(lang, "home.features.items.ai.title"),
    description: t(lang, "home.features.items.ai.description"),
    image: withBase("/ai.png"),
    imageWebp: withBase("/ai.webp"),
    badge: t(lang, "home.features.items.ai.badge"),
  },
];

const faqItems = [
  {
    question: t(lang, "faq.items.whatIs.question"),
    answer: t(lang, "faq.items.whatIs.answer"),
  },
  {
    question: t(lang, "faq.items.spacedRepetition.question"),
    answer: t(lang, "faq.items.spacedRepetition.answer"),
  },
  {
    question: t(lang, "faq.items.fsrs.question"),
    answer: t(lang, "faq.items.fsrs.answer"),
  },
  {
    question: t(lang, "faq.items.free.question"),
    answer: t(lang, "faq.items.free.answer"),
  },
  {
    question: t(lang, "faq.items.languages.question"),
    answer: t(lang, "faq.items.languages.answer"),
  },
];
---

<Layout
  title="OpenFlashcards — Self-hosted flashcards with FSRS spaced repetition & text-to-speech"
  description="Free, open-source, self-hosted flashcard app with FSRS spaced repetition and text-to-speech. Learn more in less time. MIT licensed."
  lang={lang}
  canonicalPath="/"
>
  <Header lang={lang} />

  <main id="main" class="pt-16">
    <!-- Hero Section -->
    <section id="home" class="pt-30 mb-30">
      <Container>
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-4">
          <div class="w-full flex flex-col justify-center gap-8">
            <div
              class="w-full flex flex-col items-center lg:items-start text-center lg:text-start gap-4 md:gap-6"
            >
              <h1
                class="text-on-surface max-w-2xl lg:max-w-full text-4xl md:text-hero font-semibold font-display leading-10 md:leading-14"
              >
                {t(lang, "home.section1.title")}
              </h1>

              <p
                class="flex flex-col max-w-146 text-on-surface-variant font-normal text-base md:text-lg"
              >
                {t(lang, "home.section1.paragraph")}
                <span class="font-medium text-on-surface">
                  {t(lang, "home.section1.paragraphHighlight")}
                </span>
              </p>
            </div>

            <div class="w-full flex flex-col items-center lg:items-start gap-4">
              <CtaButtons lang={lang} />
            </div>
          </div>

          <div
            class="w-full max-w-150 lg:max-w-full flex items-center justify-center relative mx-auto"
          >
            <picture>
              <source
                srcset={withBase("/mockup-banner-principal.webp")}
                type="image/webp"
              />
              <img
                src={withBase("/mockup-banner-principal.png")}
                alt={t(lang, "home.section1.title")}
                class="w-auto h-full max-h-140"
              />
            </picture>

            <div
              class="w-full max-w-47 flex flex-col gap-2.5 absolute left-5 sm:left-30 bottom-21 p-4 rounded-xl border border-outline-strong bg-surface-container-high"
              aria-hidden="true"
            >
              <span class="font-mono text-2xs uppercase tracking-wider text-primary-300">FSRS</span>
              <h4 class="text-on-surface font-medium font-display text-sm">
                {t(lang, "home.cards.progress.title")}
              </h4>
              <div class="w-full h-1.5 bg-surface-container-high rounded-full overflow-hidden">
                <div class="w-[60%] h-full bg-primary-500 rounded-full"></div>
              </div>
              <span class="text-on-surface-variant font-mono text-2xs">
                {t(lang, "home.cards.progress.progress")}
              </span>
            </div>

            <div
              class="w-full max-w-43.5 flex flex-col absolute right-0 top-35 p-4 rounded-xl border border-outline bg-surface-container"
              aria-hidden="true"
            >
              <span class="font-mono text-2xs uppercase tracking-wider text-on-surface-variant mb-2">Next review</span>
              <p class="text-primary-300 font-display font-semibold text-sm">4 days</p>
              <p class="text-on-surface-variant text-2xs mt-1">retention 90%</p>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- How It Works Section -->
    <section id="how-it-works" class="mb-30">
      <Container>
        <div
          class="w-full flex flex-col items-center justify-center text-center gap-4 mb-15 md:mb-18"
        >
          <Badge label={t(lang, "home.section2.badge")} />
          <h2
            class="text-on-surface text-3xl md:text-5xl font-semibold font-display leading-9 md:leading-12 max-w-3xl"
          >
            {t(lang, "home.section2.title")}
          </h2>
        </div>

        <HomeCardsIsland client:visible cards={cards} />
      </Container>
    </section>

    <!-- Features Carousel Section -->
    <section id="features" class="w-full overflow-hidden mb-35">
      <Container>
        <div class="flex flex-col gap-4 mb-12 lg:mb-0">
          <Badge label={t(lang, "home.features.badge")} />
          <h2
            class="max-w-100 text-on-surface font-semibold font-display text-[2rem] leading-8 md:text-5xl md:leading-14"
          >
            {t(lang, "home.features.title")}
          </h2>
        </div>

        <FeaturesCarouselIsland client:visible features={features} />
      </Container>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="mb-30">
      <Container>
        <div
          class="w-full flex flex-col items-center justify-center text-center gap-4 mb-15 md:mb-18"
        >
          <Badge label={t(lang, "faq.badge")} />
          <h2
            class="text-on-surface text-3xl md:text-5xl font-semibold font-display leading-9 md:leading-12 max-w-3xl"
          >
            {t(lang, "faq.title")}
          </h2>
        </div>

        <FAQIsland client:visible items={faqItems} />
      </Container>
    </section>

    <!-- Get Started CTA Section -->
    <section class="relative">
      <div
        class="w-full h-45.5 bg-surface-container-low border-t border-outline-variant absolute bottom-0"
      >
      </div>

      <Container>
        <div
          class="w-full bg-surface-container grid md:grid-cols-2 sm:gap-4 md:gap-6 lg:gap-11 border border-outline rounded-xl overflow-hidden"
        >
          <div class="flex items-end h-full order-2 md:order-1">
            <picture class="hidden md:block">
              <source srcset={withBase("/mockup-celular.webp")} type="image/webp" />
              <img
                src={withBase("/mockup-celular.png")}
                alt={t(lang, "home.cta.title")}
                loading="lazy"
              />
            </picture>

            <picture class="block md:hidden">
              <source srcset={withBase("/mockup-celular-2.webp")} type="image/webp" />
              <img
                src={withBase("/mockup-celular-2.png")}
                alt={t(lang, "home.cta.title")}
                loading="lazy"
              />
            </picture>
          </div>

          <div
            class="flex flex-col items-center md:items-start justify-center gap-6 py-12 md:py-20 px-4 md:px-5 order-1 md:order-2"
          >
            <div
              class="flex flex-col items-center md:items-start text-center md:text-start gap-4"
            >
              <Badge label={t(lang, "home.cta.badge")} />
              <h2
                class="text-on-surface text-3xl md:text-5xl font-semibold max-w-md leading-10 md:leading-14"
              >
                {t(lang, "home.cta.title")}
              </h2>
            </div>

            <CtaButtons lang={lang} />
          </div>
        </div>
      </Container>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>
