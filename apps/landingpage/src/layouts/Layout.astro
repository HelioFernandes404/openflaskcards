---
import "../global.css";
import {
  languages,
  defaultLang,
  type Lang,
  getLocalizedPath,
  withBase,
} from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  canonicalPath?: string;
}

const { title, description, lang = defaultLang, canonicalPath = "/" } = Astro.props;

const siteUrl = "https://heliofernandes404.github.io";
const canonicalUrl = `${siteUrl}${getLocalizedPath(lang, canonicalPath)}`;
const ogImage = `${siteUrl}${withBase("/logo.png")}`;

// Generate hreflang URLs
const hreflangUrls = Object.keys(languages).map((l) => ({
  lang: l,
  url: `${siteUrl}${getLocalizedPath(l as Lang, canonicalPath)}`,
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="flashcards, spaced repetition, FSRS, self-hosted, open source, text-to-speech, study app, active recall, education technology"
    />
    <meta name="author" content="OpenFlashcards contributors" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OpenFlashcards" />
    <meta property="og:locale" content={lang === "en" ? "en_US" : `${lang}_${lang.toUpperCase()}`} />
    {Object.keys(languages).filter((l) => l !== lang).map((l) => (
      <meta property="og:locale:alternate" content={l === "en" ? "en_US" : `${l}_${l.toUpperCase()}`} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon & Canonical -->
    <link rel="icon" type="image/png" href={withBase("/favicon.png")} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang tags -->
    {hreflangUrls.map(({ lang: l, url }) => (
      <link rel="alternate" hreflang={l} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${withBase(canonicalPath)}`} />

    <title>{title}</title>

    <!-- Schema.org structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "OpenFlashcards",
      applicationCategory: "EducationalApplication",
      operatingSystem: "Web, Docker",
      url: siteUrl,
      description: "Self-hosted flashcard app with FSRS spaced repetition and text-to-speech, free and open source under the MIT license.",
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
      },
      license: "https://opensource.org/licenses/MIT",
      featureList: [
        "Spaced repetition with the FSRS algorithm",
        "Text-to-speech for pronunciation",
        "Unlimited decks and cards",
        "Progress tracking and analytics",
        "Self-hosted with Docker",
        "Multi-language support",
      ],
      sameAs: ["https://github.com/HelioFernandes404/openflashcards"],
    })} />
  </head>
  <body class="font-inter bg-neutral-0 text-neutral-900 relative min-h-screen">
    <slot />
  </body>
</html>
